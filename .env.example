# 服务地址（生产建议仅监听本机，经 Nginx 对外暴露）
ADDR=127.0.0.1:18080
# 前端访问地址（须含端口；多个用英文逗号分隔）
FRONTEND_ORIGIN=http://106.13.115.166:18082

# 临时文件目录
TEMP_DIR=/var/lib/tools-web/tmp
MAX_UPLOAD_MB=500
MAX_DURATION_SEC=7200

# ASR 服务（仅本机）
ASR_SERVICE_URL=http://127.0.0.1:18081
ASR_PORT=18081

# 系统工具路径
FFMPEG_PATH=ffmpeg
YTDLP_PATH=yt-dlp

# 百度云 BOS（本地开发可 false）
BOS_ENABLED=false
BOS_ENDPOINT=https://bj.bcebos.com
BOS_BUCKET=
BOS_ACCESS_KEY=
BOS_SECRET_KEY=

# Whisper（asr-service 容器/进程）
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
