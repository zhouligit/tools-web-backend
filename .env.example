# 服务地址
ADDR=:8080
FRONTEND_ORIGIN=https://your-domain.com

# 临时文件目录
TEMP_DIR=/var/lib/tools-web/tmp
MAX_UPLOAD_MB=500

# ASR 服务
ASR_SERVICE_URL=http://127.0.0.1:8090

# 系统工具路径
FFMPEG_PATH=ffmpeg
YTDLP_PATH=yt-dlp

# 百度云 BOS（本地开发可 false）
BOS_ENABLED=false
BOS_ENDPOINT=https://bj.bcebos.com
BOS_BUCKET=
BOS_ACCESS_KEY=
BOS_SECRET_KEY=

# Whisper（asr-service 容器/进程）
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
